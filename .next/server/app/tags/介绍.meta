{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/tags/layout,_N_T_/tags/[tag]/layout,_N_T_/tags/[tag]/page,_N_T_/tags/%E4%BB%8B%E7%BB%8D"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/tags/$d$tag/__PAGE__",
    "/tags/$d$tag",
    "/tags",
    "/_index"
  ]
}